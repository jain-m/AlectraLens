{
  "manifest_version": 3,
  "name": "AlectraLens",
  "version": "1.1",
  "description": "A browser extension that provides quick summarization and content analysis tools using local models and the Gemini API.",
  "author": "Manisha Jain",
  "homepage_url": "https://github.com/jain-m/AlectraLens",
  "action": {"default_popup": "popup.html"},
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "permissions": ["contextMenus", "scripting", "activeTab", "storage"],
  "options_page": "options.html",
  "host_permissions": [ "<all_urls>" ],
  "background": { "service_worker": "background.js" }
}
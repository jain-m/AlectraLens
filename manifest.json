{
  "manifest_version": 3,
  "name": "AlectraLens",
  "version": "1.1",
  "action": {"default_popup": "popup.html"},
  "permissions": ["contextMenus", "scripting", "activeTab", "storage"],
  "options_page": "options.html",
  "host_permissions": [ "<all_urls>" ],
  "background": { "service_worker": "background.js" }
}